JARVIS_PRIMARY.ENV="local"

JARVIS_SERVER.PORT="8080"
JARVIS_SERVER.READ_TIMEOUT="30"
JARVIS_SERVER.WRITE_TIMEOUT="30"
JARVIS_SERVER.IDLE_TIMEOUT="60"
JARVIS_SERVER.CORS_ALLOWED_ORIGINS="http://localhost:3000"

JARVIS_DATABASE.HOST="localhost"
JARVIS_DATABASE.PORT="5432"
JARVIS_DATABASE.USER="postgres"
JARVIS_DATABASE.PASSWORD=""
JARVIS_DATABASE.NAME="jarvis"
JARVIS_DATABASE.SSL_MODE="disable"
JARVIS_DATABASE.MAX_OPEN_CONNS="25"
JARVIS_DATABASE.MAX_IDLE_CONNS="25"
JARVIS_DATABASE.CONN_MAX_LIFETIME="300"
JARVIS_DATABASE.CONN_MAX_IDLE_TIME="300"

JARVIS_AUTH.SECRET_KEY="secret"

JARVIS_INTEGRATION.RESEND_API_KEY="resend_key"

JARVIS_REDIS.ADDRESS="redis://localhost:6379"

# ============================================================================
# OBSERVABILITY CONFIGURATION
# ============================================================================

# Service Identity
JARVIS_OBSERVABILITY.SERVICE_NAME="jarvis"
JARVIS_OBSERVABILITY.ENVIRONMENT="development"

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Basic Logging Settings
JARVIS_OBSERVABILITY.LOGGING.LEVEL="debug"
JARVIS_OBSERVABILITY.LOGGING.FORMAT="console"
JARVIS_OBSERVABILITY.LOGGING.SLOW_QUERY_THRESHOLD="100ms"

# ============================================================================
# NEW RELIC CONFIGURATION
# ============================================================================

# New Relic APM
JARVIS_OBSERVABILITY.NEW_RELIC.LICENSE_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
JARVIS_OBSERVABILITY.NEW_RELIC.APP_LOG_FORWARDING_ENABLED="true"
JARVIS_OBSERVABILITY.NEW_RELIC.DISTRIBUTED_TRACING_ENABLED="true"
JARVIS_OBSERVABILITY.NEW_RELIC.DEBUG_LOGGING="false"

# ============================================================================
# HEALTH CHECKS CONFIGURATION
# ============================================================================

# Health Check Settings
JARVIS_OBSERVABILITY.HEALTH_CHECKS.ENABLED="true"
JARVIS_OBSERVABILITY.HEALTH_CHECKS.INTERVAL="30s"
JARVIS_OBSERVABILITY.HEALTH_CHECKS.TIMEOUT="5s"
JARVIS_OBSERVABILITY.HEALTH_CHECKS.CHECKS="database,redis"